local function addMoveToggle(y, label, getState, onToggle)
	local r = Instance.new("Frame", MoveGroup)
	r.BackgroundTransparency = 1
	r.Position = UDim2.new(0, 12, 0, y)
	r.Size = UDim2.new(1, -24, 0, 18)

	local b = Instance.new("TextButton", r)
	b.BackgroundColor3 = getState() and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22)
	b.BorderSizePixel = 0
	b.Position = UDim2.new(0, 0, 0.5, -5)
	b.Size = UDim2.new(0, 10, 0, 10)
	b.Text = ""
	Instance.new("UIStroke", b).Color = Color3.fromRGB(55, 55, 55)
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 2)

	local l = Instance.new("TextButton", r)
	l.BackgroundTransparency = 1
	l.Position = UDim2.new(0, 16, 0, 0)
	l.Size = UDim2.new(1, -16, 1, 0)
	l.Font = Enum.Font.SourceSans
	l.Text = label
	l.TextColor3 = getState() and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145)
	l.TextSize = 13
	l.TextXAlignment = Enum.TextXAlignment.Left

	local function refresh()
		local on = getState()
		b.BackgroundColor3 = on and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22)
		l.TextColor3 = on and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145)
	end

	b.MouseButton1Click:Connect(function()
		onToggle()
		refresh()
	end)
	l.MouseButton1Click:Connect(function()
		onToggle()
		refresh()
	end)
	refresh()
end

