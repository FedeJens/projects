local function setSpeedVal(val)
	SpeedStudsPerSecond = math.clamp(math.floor(val), minS, maxS)
	sliderLabel.Text = "studs per second: " .. SpeedStudsPerSecond
	SpeedMultiplierValue = SpeedStudsPerSecond / 16
	CustomSpeedMultiplier = SpeedStudsPerSecond / 16

	-- Also control fly speed with the same slider
	FlySpeedValue = SpeedStudsPerSecond
	CustomFlySpeed = SpeedStudsPerSecond

	fill.Size = UDim2.new((SpeedStudsPerSecond - minS) / (maxS - minS), 0, 1, 0)
	nub.Position = UDim2.new((SpeedStudsPerSecond - minS) / (maxS - minS), -6, 0.5, -8)

	-- If speed is currently active, update immediately
	if CFrameSpeedActive then
		local char = LocalPlayer.Character
		local hum = char and char:FindFirstChild("Humanoid")
		if hum then hum.WalkSpeed = SpeedStudsPerSecond end
	end

	-- If fly is currently active, the next RenderStepped frame will use the new speed
end

