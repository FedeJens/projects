local function ApplyTheme()
	if not Frame then return end

	for _, obj in ipairs(Frame:GetDescendants()) do
		if obj:IsA("TextLabel") or obj:IsA("TextButton") then
			local txt = obj.Text or ""

			-- Section headers (— rage, — settings, etc.)
			if txt:find("^—") then
				obj.TextColor3 = Theme.SectionText

			-- Sidebar tab buttons
			elseif obj.Parent and obj.Parent == UI.Frame_7 then
				if obj.TextColor3 == Theme.SidebarActive or obj.Text == "ragebot" or obj.Text == "visuals" or obj.Text == "misc" then
					obj.TextColor3 = Theme.SidebarActive
				else
					obj.TextColor3 = Theme.TabText
				end

			-- Toggle labels ("force hit", "desync", etc.)
			elseif obj.Parent and obj.Parent:IsA("Frame") and obj.Parent.Parent and obj.Parent.Parent.Name == "rage" or obj.Parent.Parent.Name == "flight & speed" then
				obj.TextColor3 = Theme.ToggleText

			elseif txt:find("^Speed:") or txt:find("^Radius:") or txt:find("^Height:") then
				-- Protect target strafe slider labels
				obj.TextColor3 = Color3.fromRGB(230, 230, 230)

			else
				-- Default text
				if obj.TextColor3 == Color3.fromRGB(230, 230, 230) or obj.TextColor3 == Color3.fromRGB(200, 200, 200) then
					obj.TextColor3 = Theme.TextActive
				elseif obj.TextColor3 == Color3.fromRGB(145, 145, 145) then
					obj.TextColor3 = Theme.TextInactive
				end
			end
		end

		-- Accent elements
		if obj:IsA("Frame") and obj.BackgroundColor3 == Color3.fromRGB(215, 60, 60) then
			obj.BackgroundColor3 = Theme.Accent
		end
		if obj:IsA("UIStroke") and obj.Color == Color3.fromRGB(215, 60, 60) then
			obj.Color = Theme.Accent
		end
	end
end

