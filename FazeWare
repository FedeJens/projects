local function GetPlayerClosestToMouse()
	local MousePos = Vector2.new(Mouse.X, Mouse.Y)
	local Character = LocalPlayer.Character
	local MyTorso = Character and Character:FindFirstChild("UpperTorso")
	if not MyTorso then return nil, 0 end

	local ClosestPlayer = nil
	local ClosestScreenDist = math.huge
	local ClosestWorldDist = 0

	for _, Player in ipairs(Players:GetPlayers()) do
		if Player ~= LocalPlayer and Player.Character then
			local TargetHead = Player.Character:FindFirstChild("Head")
			local TargetHum = Player.Character:FindFirstChildOfClass("Humanoid")
			local TgtBodyEffects = Player.Character:FindFirstChild("BodyEffects")
			local IsKO = TgtBodyEffects and TgtBodyEffects:FindFirstChild("K.O") and TgtBodyEffects["K.O"].Value

			if TargetHead and TargetHum and TargetHum.Health > 0 and not IsKO then
				local ScreenPos, OnScreen = Camera:WorldToScreenPoint(TargetHead.Position)
				if OnScreen then
					local ScreenDist = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
					if ScreenDist < ClosestScreenDist then
						local WorldDist = (TargetHead.Position - MyTorso.Position).Magnitude
						local RayDirection = (TargetHead.Position - MyTorso.Position).Unit * WorldDist
						local RayParams = RaycastParams.new()
						RayParams.FilterType = Enum.RaycastFilterType.Exclude
						RayParams.FilterDescendantsInstances = { workspace.Ignored, workspace.Players, Character }

						local WallCheck = workspace:Raycast(MyTorso.Position, RayDirection, RayParams)

						if not WallCheck then
							ClosestScreenDist = ScreenDist
							ClosestWorldDist = WorldDist
							ClosestPlayer = Player.Character
						end
					end
				end
			end
		end
	end

	return ClosestPlayer, ClosestWorldDist
end

local function FireWeaponAtTarget()
	if not ForceHitActive or not LockedTarget then return end

	local Character = LocalPlayer.Character
	local Tool = Character and Character:FindFirstChildOfClass("Tool")
	if not Tool then return end

	if HasForceField(LockedTarget) then return end

	local Handle = Tool:FindFirstChild("Handle")
	local GunScript = Tool:FindFirstChild("Script")
	local Ammo = GunScript and GunScript:FindFirstChild("Ammo") and GunScript.Ammo:FindFirstChild("CLIENT")

	if Ammo and Ammo.Value <= 0 then
		if Handle and Handle:FindFirstChild("NoAmmo") then Handle.NoAmmo:Play() end
		return
	end

	local BodyEffects = Character:FindFirstChild("BodyEffects")
	if BodyEffects and BodyEffects:FindFirstChild("Reloading_CLIENT") and BodyEffects.Reloading_CLIENT.Value == true then
		return
	end

	local IsShotgun = Tool.Name == "[DoubleBarrel]" or Tool.Name == "[Shotgun]" or Tool.Name == "[TacticalShotgun]"

	local MyRoot = Character:FindFirstChild("HumanoidRootPart")
	local MyTorso = Character:FindFirstChild("UpperTorso")
	if not MyTorso or not MyRoot then return end

	local TargetRoot = LockedTarget:FindFirstChild("HumanoidRootPart")
	local TargetHum = LockedTarget:FindFirstChildOfClass("Humanoid")
	if not TargetRoot or not TargetHum or TargetHum.Health <= 0 then return end

	local BasePosition = TargetRoot.Position
	local OriginPosition = Handle and Handle.Position or MyRoot.Position
	local ServerTime = workspace:GetServerTimeNow()

	if Ammo then Ammo.Value = math.max(0, Ammo.Value - 1) end

	if Handle and Handle:FindFirstChild("Shoot") then
		local AudioClone = Handle.Shoot:Clone()
		game:GetService("Debris"):AddItem(AudioClone, 2)
		AudioClone.Parent = Handle
		AudioClone:Play()
	end

	local RayHitTable = {}
	local OffsetTable = {}

	local ShotgunPelletSpreadFactors = { -1.35, -0.9, 0.25, 0.55, 1 }
	local RayCount = IsShotgun and 5 or 1

	local LocalRandomGenerator = Random.new(ServerTime)
	local AngleRotation = CFrame.Angles(0, 0, math.rad(LocalRandomGenerator:NextNumber(-90, 90)))
	local Multiplier = LocalRandomGenerator:NextNumber(0, 5.75)
	local DirectSign = (LocalRandomGenerator:NextInteger(0, 1) == 1) and 1 or -1
	local CalculatedSpread = Multiplier * DirectSign

	if CalculatedSpread > -0.35 and CalculatedSpread < 0.35 then
		CalculatedSpread = 0.35
	end

	for i = 1, RayCount do
		local FinalSimulatedHitPos = BasePosition

		if IsShotgun then
			local SpreadAngle = ShotgunPelletSpreadFactors[i] * CalculatedSpread
			local SpreadCFrame = CFrame.new(OriginPosition, BasePosition) * AngleRotation * CFrame.Angles(math.rad(SpreadAngle), 0, 0)
			FinalSimulatedHitPos = OriginPosition + (SpreadCFrame.LookVector * (BasePosition - OriginPosition).Magnitude)
		end

		local CalculatedNormal = (OriginPosition - FinalSimulatedHitPos).Unit

		table.insert(RayHitTable, {
			Instance = TargetRoot,
			Position = FinalSimulatedHitPos,
			Normal = CalculatedNormal
		})

		table.insert(OffsetTable, {
			thePart = TargetRoot,
			theOffset = TargetRoot.CFrame:PointToObjectSpace(FinalSimulatedHitPos)
		})
	end

	if TargetHum then
		local BaseDamage = (Tool.Name == "[DoubleBarrel]") and 14 or 20
		local TotalDamage = IsShotgun and (BaseDamage * 5) or BaseDamage

		if TargetHum.Health - TotalDamage < 0.5 then
			TargetHum.Health = 0.5
		else
			TargetHum:TakeDamage(TotalDamage)
		end
		ReplicatedStorage.MainBindedEvent:Fire("DamageIndicatorText", TotalDamage, BasePosition, true, false)
	end

	ReplicatedStorage.MainEvent:FireServer("Shoot", {
		RayHitTable,
		OffsetTable,
		OriginPosition,
		BasePosition,
		ServerTime
	})
end

local function StartFiringLoop()
	IsFiring = true
	while IsFiring and ForceHitActive do
		FireWeaponAtTarget()
		task.wait(0.30)
	end
end

