local function SimulateReloadKey()
	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.R, false, game)
	task.wait(0.05)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.R, false, game)
end

local function AutoReload()
	if not AutoReloadActive then return end

	local currentTime = tick()
	if currentTime - LastReloadAttempt < ReloadCooldown then
		return
	end

	local Character = LocalPlayer.Character
	if not Character then return end

	local Tool = Character:FindFirstChildOfClass("Tool")
	if not Tool then return end

	local GunScript = Tool:FindFirstChild("Script")
	if not GunScript then return end

	local Ammo = GunScript:FindFirstChild("Ammo") and GunScript.Ammo:FindFirstChild("CLIENT")
	if not Ammo then return end

	local BodyEffects = Character:FindFirstChild("BodyEffects")
	if not BodyEffects then return end

	local IsReloading = BodyEffects:FindFirstChild("Reloading_CLIENT") and BodyEffects.Reloading_CLIENT.Value == true

	local CanReload = true
	if Tool.Name == "[Flintlock]" then
		local CanReloadValue = GunScript:FindFirstChild("CAN_RELOAD")
		if CanReloadValue then
			CanReload = CanReloadValue.Value
		end
	end

	if Ammo.Value <= 0 and not IsReloading and CanReload then
		LastReloadAttempt = currentTime
		SimulateReloadKey()
	end
end

