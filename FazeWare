		if UI.SpeedToggleBox then UI.SpeedToggleBox.BackgroundColor3 = CFrameSpeedActive and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22) end
		if UI.SpeedToggleLabel then UI.SpeedToggleLabel.TextColor3 = CFrameSpeedActive and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145) end
	elseif input.KeyCode == TargetStrafeKey then
		StrafeEnabled = not StrafeEnabled
		if StrafeEnabled then
			CreateGhost()
		else
