-- RakNet hook from the provided script (this is the correct way)
local function RakHook(packet)
	if packet.PacketId == 0x1B then
		local data = packet.AsBuffer

		if SpoofToggled then
			local maxOffset = math.max(Config.X, Config.Y, Config.Z)

			if buffer.len(data) > maxOffset + 4 then
				buffer.writeu8(data, 25, 1)
				buffer.writef32(data, Config.X, 0.0)
				buffer.writef32(data, Config.Y, 65.0)
				buffer.writef32(data, Config.Z, 0.0)
			end
		end

		if RakToggled then
			buffer.writeu32(data, 1, 0xFFFFFFFF)
		end

		packet:SetData(data)
	end
end

-- Register once
if raknet and raknet.add_send_hook then
	raknet.add_send_hook(RakHook)
end

