local function makeGroupbox(parent, y, h, title)
	local g = Instance.new("Frame")
	g.Parent = parent
	g.BackgroundColor3 = Theme.GroupboxBG
	g.BorderSizePixel = 0
	g.Position = UDim2.new(0, 12, 0, y)
	g.Size = UDim2.new(0, 240, 0, h)
	Instance.new("UICorner", g).CornerRadius = UDim.new(0, 8)
	local ln = Instance.new("Frame", g)
	ln.BackgroundColor3 = Theme.Separator
	ln.BorderSizePixel = 0
	ln.Position = UDim2.new(0, 10, 0, 0)
	ln.Size = UDim2.new(1, -20, 0, 1)
	local tt = Instance.new("TextLabel", g)
	tt.BackgroundTransparency = 1
	tt.Position = UDim2.new(0, 12, 0, 5)
	tt.Size = UDim2.new(0, 100, 0, 14)
	tt.Font = Enum.Font.SourceSans
	tt.Text = title
	tt.TextColor3 = Theme.TextActive
	tt.TextSize = 12
	tt.TextXAlignment = Enum.TextXAlignment.Left
	return g
end

local function makeCheckbox(parent, y, text, key, def, espTable)
	local r = Instance.new("Frame", parent)
	r.BackgroundTransparency = 1
	r.Position = UDim2.new(0, 12, 0, y)
	r.Size = UDim2.new(1, -24, 0, 18)

	local b = Instance.new("TextButton", r)
	b.BackgroundColor3 = def and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22)
	b.BorderSizePixel = 0
	b.Position = UDim2.new(0, 0, 0.5, -5)
	b.Size = UDim2.new(0, 10, 0, 10)
	b.Text = ""
	Instance.new("UIStroke", b).Color = Color3.fromRGB(55, 55, 55)
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 2)

	local l = Instance.new("TextButton", r)
	l.BackgroundTransparency = 1
	l.Position = UDim2.new(0, 16, 0, 0)
	l.Size = UDim2.new(1, -16, 1, 0)
	l.Font = Enum.Font.SourceSans
	l.Text = text
	l.TextColor3 = def and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145)
	l.TextSize = 13
	l.TextXAlignment = Enum.TextXAlignment.Left

	local on = def
	local function u()
		b.BackgroundColor3 = on and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22)
		l.TextColor3 = on and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145)
	end
	local function tog()
		on = not on
		if espTable then espTable[key] = on end
		u()
	end
	b.MouseButton1Click:Connect(tog)
	l.MouseButton1Click:Connect(tog)
	u()
	return b, l, function() return on end
end

