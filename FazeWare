end

local function updateESP()
	local cam = workspace.CurrentCamera
	local myChar = LocalPlayer.Character
	local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

	for p, o in pairs(ESPObjects) do
		local char = p.Character
		local head = getHead(char)
		local root = char and char:FindFirstChild("HumanoidRootPart")
		local hum = char and char:FindFirstChildOfClass("Humanoid")

		local on = ESP.Enabled and char and head and root and hum and hum.Health > 0
		local pos, onScr = nil, false
		if on then
			pos, onScr = cam:WorldToViewportPoint(root.Position)
		end

		if not on or not onScr then
			if o.box1 then o.box1.Visible = false end
			if o.box2 then o.box2.Visible = false end
			if o.tracer then o.tracer.Visible = false end
			if o.bb then o.bb.Enabled = false end
			if o.hl then o.hl.Enabled = false end
		end

		if not (on and onScr) then
			-- already hid above
		else
			local dist = myRoot and math.floor((root.Position - myRoot.Position).Magnitude) or 0

			-- Proper projected box sizing (fixes boxes becoming huge when far)
			local headPos = root.Position + Vector3.new(0, 2.8, 0)
			local footPos = root.Position - Vector3.new(0, 2.8, 0)

			local top2D, topOn = cam:WorldToViewportPoint(headPos)
			local bot2D, botOn = cam:WorldToViewportPoint(footPos)

			local height = 0
			local width = 0
			local x = pos.X
			local y = pos.Y

			if topOn and botOn then
				height = math.abs(top2D.Y - bot2D.Y)
				width = height * 0.6

				width = math.clamp(width, 8, 380)
				height = math.clamp(height, 12, 620)

				x = (top2D.X + bot2D.X) * 0.5
				y = (top2D.Y + bot2D.Y) * 0.5
			end

			if ESP.Box and topOn and botOn then
				o.box1.Size = Vector2.new(width, height)
				o.box1.Position = Vector2.new(x - width/2, y - height/2)
				o.box1.Visible = true

				o.box2.Size = Vector2.new(width - 4, height - 4)
				o.box2.Position = Vector2.new(x - (width-4)/2, y - (height-4)/2)
				o.box2.Visible = true
			else
				o.box1.Visible = false
				o.box2.Visible = false
			end

			if ESP.Tracers and myRoot then
				local myPos = cam:WorldToViewportPoint(myRoot.Position)
				o.tracer.From = Vector2.new(myPos.X, myPos.Y)
				-- Point tracer to bottom center of the projected box
				o.tracer.To = Vector2.new(x, y + height/2)
				o.tracer.Visible = true
			else
				o.tracer.Visible = false
			end

			if ESP.Name then
				o.bb.Enabled = true
				o.bb.Adornee = head
				o.nameLbl.Text = p.DisplayName or p.Name
				o.distLbl.Text = "(" .. dist .. " studs)"
			else
				o.bb.Enabled = false
			end

			if o.hl then
				o.hl.Enabled = ESP.Highlight
				if ESP.Highlight and o.hl.Parent ~= char then
					o.hl.Parent = char
				end
			end
		end
	end
end

