-- Helper to create a toggle button (matches existing style in the script)
local function CreateESPToggle(parent, yOffset, labelText, defaultState, onToggle)
    local row = Instance.new("Frame")
    row.Name = labelText:gsub(" ", "") .. "Row"
    row.Parent = parent
    row.BackgroundTransparency = 1
    row.Position = UDim2.new(0, 12, 0, yOffset)
    row.Size = UDim2.new(1, -24, 0, 22)

    local box = Instance.new("TextButton")
    box.Name = "CheckboxBox"
    box.Parent = row
    box.BackgroundColor3 = defaultState and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22)
    box.BorderSizePixel = 0
    box.Position = UDim2.new(0, 0, 0.5, -5)
    box.Size = UDim2.new(0, 12, 0, 12)
    box.Text = ""
    box.AutoButtonColor = false

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(55, 55, 55)
    stroke.Thickness = 1
    stroke.Parent = box

    local label = Instance.new("TextButton")
    label.Name = "CheckboxLabel"
    label.Parent = row
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 18, 0, 0)
    label.Size = UDim2.new(1, -18, 1, 0)
    label.Font = Enum.Font.SourceSans
    label.Text = labelText
    label.TextColor3 = defaultState and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145)
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.AutoButtonColor = false

    local enabled = defaultState

    local function UpdateVisual()
        box.BackgroundColor3 = enabled and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22)
        label.TextColor3 = enabled and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145)
    end

    local function Toggle()
        enabled = not enabled
        UpdateVisual()
        if onToggle then
            onToggle(enabled)
        end
    end

    box.MouseButton1Click:Connect(Toggle)
    label.MouseButton1Click:Connect(Toggle)

    UpdateVisual()

    return {
        Set = function(state)
            enabled = state
            UpdateVisual()
            if onToggle then onToggle(enabled) end
        end,
        Get = function() return enabled end
    }
end

