local function LoadConfig()
	if not isfile or not readfile then return end
	if not isfile(FileName) then return end

	local success, content = pcall(function()
		return readfile(FileName)
	end)

	if success then
		local decodeSuccess, decoded = pcall(function()
			return HttpService:JSONDecode(content)
		end)

		if decodeSuccess and decoded then
			if decoded.ActivationKey then ActivationKey = Enum.KeyCode[decoded.ActivationKey] end
			if decoded.SpoofKey then Config.SpoofKey = Enum.KeyCode[decoded.SpoofKey] end
			if decoded.RakKey then Config.RakKey = Enum.KeyCode[decoded.RakKey] end
			if decoded.DesyncKey then Config.DesyncKey = Enum.KeyCode[decoded.DesyncKey] end
			if decoded.FlyToggleKey then FlyToggleKey = Enum.KeyCode[decoded.FlyToggleKey] 
				FlyKeybindBtn.Text = FlyToggleKey.Name end
			if decoded.SpeedToggleKey then SpeedToggleKey = Enum.KeyCode[decoded.SpeedToggleKey]
				SpeedKeybindBtn.Text = SpeedToggleKey.Name end

			ForceHitTextEnabled = decoded.ForceHitTextEnabled or false
			SpoofTextEnabled = decoded.SpoofTextEnabled or false
			RakTextEnabled = decoded.RakTextEnabled or false
			DesyncTextEnabled = decoded.DesyncTextEnabled or false
			AutoReloadActive = decoded.AutoReloadActive or false
			
			if decoded.FlySpeed then UpdateFlySpeed(decoded.FlySpeed) end
			if decoded.SpeedMultiplier then UpdateSpeedMultiplier(decoded.SpeedMultiplier) end

