UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end

	if IsBinding and BindingTarget then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			local key = input.KeyCode
			if BindingTarget == "ForceHit" then
				ActivationKey = key
			elseif BindingTarget == "Desync" then
				Config.DesyncKey = key
			elseif BindingTarget == "Fly" then
				FlyToggleKey = key
			elseif BindingTarget == "Speed" then
				SpeedToggleKey = key
			elseif BindingTarget == "MenuToggle" then
				MenuToggleKey = key
			elseif BindingTarget == "TargetStrafe" then
				TargetStrafeKey = key
			end

			-- Update the bind button text directly using stored reference
			if BindButtons[BindingTarget] then
				local b = BindButtons[BindingTarget]
				b.Text = string.lower(key.Name)
				b.TextColor3 = Color3.fromRGB(180, 180, 180)
			end

			-- Special refresh for target strafe bind if it exists in rage tab
			if BindingTarget == "TargetStrafe" and BindButtons["TargetStrafe"] then
				BindButtons["TargetStrafe"].Text = string.lower(TargetStrafeKey.Name)
				BindButtons["TargetStrafe"].TextColor3 = Color3.fromRGB(180, 180, 180)
			end

			IsBinding = false
			BindingTarget = nil
		end
		return
	end

	if input.KeyCode == MenuToggleKey then
		Frame.Visible = not Frame.Visible
	elseif input.KeyCode == ActivationKey then
		ForceHitActive = not ForceHitActive
		if ForceHitActive then
			local closest, _ = GetPlayerClosestToMouse()
			if closest then
				LockedTarget = closest
				if not IsFiring then
					task.spawn(StartFiringLoop)
				end
			end
		else
			LockedTarget = nil
			IsFiring = false
			if ForceHitTextEnabled then
				SetNoTarget()
			else
				Beam.Enabled = false
				HUDFrame.Visible = false
			end
		end
	elseif input.KeyCode == Config.DesyncKey then
		local newState = not DesyncToggled   -- master state from the provided script

		-- The Desync key now controls Spoof + Raknet + Desync using the correct RakNet hook + sleeping method
		SpoofToggled = newState
		RakToggled = newState
		DesyncToggled = newState

		SpoofActive = newState
		RakActive = newState
		DesyncActive = newState

		SpoofTextEnabled = newState
		RakTextEnabled = newState
		DesyncTextEnabled = newState

		UpdateLabels()
		NotifyDesync("Spoof/Rak/Desync " .. (newState and "Enabled" or "Disabled"))
	elseif input.KeyCode == FlyToggleKey then
		local newState = not CFrameFlyActive
		if newState then startFlying() else stopFlying() end
		if UI.FlyToggleBox then UI.FlyToggleBox.BackgroundColor3 = CFrameFlyActive and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22) end
		if UI.FlyToggleLabel then UI.FlyToggleLabel.TextColor3 = CFrameFlyActive and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145) end
	elseif input.KeyCode == SpeedToggleKey then
		local newState = not CFrameSpeedActive
