local function SimulateReloadKey()
	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.R, false, game)
	task.wait(0.05)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.R, false, game)
end

local function AutoReload()
	if not AutoReloadActive then return end
	
	local currentTime = tick()
	if currentTime - LastReloadAttempt < ReloadCooldown then
		return
	end
	
	local Character = LocalPlayer.Character
	if not Character then return end
	
	local Tool = Character:FindFirstChildOfClass("Tool")
	if not Tool then return end
	
	local GunScript = Tool:FindFirstChild("Script")
	if not GunScript then return end
	
	local Ammo = GunScript:FindFirstChild("Ammo") and GunScript.Ammo:FindFirstChild("CLIENT")
	if not Ammo then return end
	
	local BodyEffects = Character:FindFirstChild("BodyEffects")
	if not BodyEffects then return end
	
	local IsReloading = BodyEffects:FindFirstChild("Reloading_CLIENT") and BodyEffects.Reloading_CLIENT.Value == true
	
	local CanReload = true
	if Tool.Name == "[Flintlock]" then
		local CanReloadValue = GunScript:FindFirstChild("CAN_RELOAD")
		if CanReloadValue then
			CanReload = CanReloadValue.Value
		end
	end
	
	if Ammo.Value <= 0 and not IsReloading and CanReload then
		LastReloadAttempt = currentTime
		SimulateReloadKey()
	end
end

local function GetFlySpeed()
	if CustomFlySpeed and type(CustomFlySpeed) == "number" then
		return CustomFlySpeed
	end
	return FlySpeedValue or 50
end

local function GetSpeedMultiplier()
	if CustomSpeedMultiplier and type(CustomSpeedMultiplier) == "number" then
		return CustomSpeedMultiplier
	end
	return SpeedMultiplierValue or 2
end

local function startFlying()
	local character = LocalPlayer.Character
	local hrp = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChild("Humanoid")
	
	if not hrp or not humanoid then return end
	
	CFrameFlyActive = true
	
	if not bodyVelocity then
		bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.Velocity = Vector3.new(0, 0, 0)
		bodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
	end
	
	if not bodyGyro then
		bodyGyro = Instance.new("BodyGyro")
		bodyGyro.CFrame = hrp.CFrame
		bodyGyro.MaxTorque = Vector3.new(100000, 100000, 100000)
	end
	
	bodyVelocity.Parent = hrp
	bodyGyro.Parent = hrp
	humanoid.PlatformStand = true
end

local function stopFlying()
	local character = LocalPlayer.Character
	local hrp = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChild("Humanoid")
	
	CFrameFlyActive = false
	
	if bodyVelocity then
		bodyVelocity.Parent = nil
	end
	if bodyGyro then
		bodyGyro.Parent = nil
	end
	if humanoid then
		humanoid.PlatformStand = false
	end
end

local function startSpeed()
	CFrameSpeedActive = true
	if speedConnection then
		speedConnection:Disconnect()
		speedConnection = nil
	end
	
	speedConnection = RunService.Heartbeat:Connect(function()
		local character = LocalPlayer.Character
		local humanoid = character and character:FindFirstChild("Humanoid")
		
		if not humanoid or not CFrameSpeedActive then
			return end
		
		if originalWalkSpeed == 16 then
			originalWalkSpeed = humanoid.WalkSpeed
		end
		
		local speedMult = GetSpeedMultiplier()
		humanoid.WalkSpeed = originalWalkSpeed * speedMult
	end)
end

local function stopSpeed()
	CFrameSpeedActive = false
	if speedConnection then
		speedConnection:Disconnect()
		speedConnection = nil
	end
	local character = LocalPlayer.Character
	local humanoid = character and character:FindFirstChild("Humanoid")
	if humanoid and originalWalkSpeed then
		humanoid.WalkSpeed = originalWalkSpeed
	end
end

local function toggleFly()
	if CFrameFlyActive then
		stopFlying()
	else
		startFlying()
	end
	FlyToggleBox.BackgroundColor3 = CFrameFlyActive and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22)
	FlyToggleLabel.TextColor3 = CFrameFlyActive and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145)
end

local function toggleSpeed()
	if CFrameSpeedActive then
		stopSpeed()
	else
		startSpeed()
	end
	SpeedToggleBox.BackgroundColor3 = CFrameSpeedActive and Color3.fromRGB(215, 60, 60) or Color3.fromRGB(22, 22, 22)
	SpeedToggleLabel.TextColor3 = CFrameSpeedActive and Color3.fromRGB(230, 230, 230) or Color3.fromRGB(145, 145, 145)
end

