                    obj.Enabled = false
                else
                    obj.Visible = false
                end
            end
            continue
        end

        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        local top, _ = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1, 0))
        local bottom = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

        local xSize = 2000 / pos.Z
        local ySize = 2500 / pos.Z
        local v2Pos = Vector2.new(pos.X - xSize/2, top.Y)
        local size = Vector2.new(xSize, bottom.Y - top.Y)

        -- Box
        if objects.box and ESP.Box then
            objects.box.Size = size
            objects.box.Position = v2Pos
            objects.box.Visible = onScreen

            objects.boxOutline.Size = size
            objects.boxOutline.Position = v2Pos
            objects.boxOutline.Visible = onScreen
        end

        -- Name + Distance
        if objects.name and ESP.Name then
            local dist = math.floor((hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude)
            objects.name.Text = player.Name .. " [" .. dist .. "]"
            objects.name.Position = Vector2.new(pos.X, v2Pos.Y - 16)
            objects.name.Visible = onScreen
        end

        -- Tracer
        if objects.tracer and ESP.Tracers then
            objects.tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            objects.tracer.To = Vector2.new(pos.X, pos.Y)
            objects.tracer.Visible = onScreen
        end

        -- Highlight (Chams)
        if objects.highlight and ESP.Highlight then
            objects.highlight.Adornee = char
            objects.highlight.Enabled = onScreen
        end
    end
end)

-- Player management
local function onPlayerAdded(player)
    if player == LocalPlayer then return end
    createESPForPlayer(player)

    player.CharacterAdded:Connect(function()
        task.wait(0.5)
        if ESP.Enabled then
            removeESPForPlayer(player)
            createESPForPlayer(player)
        end
    end)
end

local function onPlayerRemoving(player)
    removeESPForPlayer(player)
end

for _, player in ipairs(Players:GetPlayers()) do
    onPlayerAdded(player)
end

Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)

