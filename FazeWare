local function CreateGhost()
    if Ghost then
        Ghost:Destroy()
    end

    local char = LocalPlayer.Character
    if not char then return end

    Ghost = char:Clone()
    Ghost.Name = "Ghost"
    Ghost.Parent = workspace

    for _, part in ipairs(Ghost:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 0.25   -- 25% transparent as requested
            part.CanCollide = false
            part.CanQuery = false
            part.CanTouch = false
        elseif part:IsA("Decal") or part:IsA("Texture") then
            part.Transparency = 0.25
        end
    end

    -- Make the ghost the camera subject so you see through it
    if Ghost:FindFirstChild("Humanoid") then
        Camera.CameraSubject = Ghost.Humanoid
    end
end

local function DestroyGhost()
    if Ghost then
        Ghost:Destroy()
        Ghost = nil
    end
    -- Restore camera to real character
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        Camera.CameraSubject = char.Humanoid
    end
end

-- Main strafe logic (360° around target)
RunService.RenderStepped:Connect(function()
    if not StrafeEnabled then return end
    if not LockedTarget or not LockedTarget:FindFirstChild("HumanoidRootPart") then return end
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local targetHRP = LockedTarget.HumanoidRootPart
    local myHRP = char.HumanoidRootPart

    local angle = tick() * StrafeSpeed
    local offset = Vector3.new(math.cos(angle) * StrafeRadius, StrafeHeight, math.sin(angle) * StrafeRadius)

    local desiredPos = targetHRP.Position + offset

    -- Strafe the real character (what enemies see)
    myHRP.CFrame = CFrame.new(desiredPos, targetHRP.Position)

    -- Keep velocity clean so it doesn't fight the CFrame
    myHRP.Velocity = Vector3.new(0, myHRP.Velocity.Y, 0)
end)

