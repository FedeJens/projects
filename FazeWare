-- ========== THEME CONTROLS ==========
local function ApplyTheme()
	if not Frame then return end

	for _, obj in ipairs(Frame:GetDescendants()) do
		if obj:IsA("TextLabel") or obj:IsA("TextButton") then
			local txt = obj.Text or ""

			if txt:find("^—") then
				obj.TextColor3 = Theme.SectionText
			elseif obj.Parent == UI.Frame_7 then
				obj.TextColor3 = (obj.TextColor3 == Theme.SidebarActive) and Theme.SidebarActive or Theme.TabText
			elseif txt:find("^Speed:") or txt:find("^Radius:") or txt:find("^Height:") then
				-- Keep slider labels in target strafe bright and visible
				obj.TextColor3 = Color3.fromRGB(230, 230, 230)
			else
				obj.TextColor3 = Theme.ToggleText
			end
		end

		if obj:IsA("Frame") and obj.BackgroundColor3 == Color3.fromRGB(215, 60, 60) then
			obj.BackgroundColor3 = Theme.Accent
		end
		if obj:IsA("UIStroke") and obj.Color == Color3.fromRGB(215, 60, 60) then
			obj.Color = Theme.Accent
		end
	end
end

