local function startSpeed()
	CFrameSpeedActive = true
	if speedConnection then
		speedConnection:Disconnect()
		speedConnection = nil
	end

	speedConnection = RunService.Heartbeat:Connect(function()
		local character = LocalPlayer.Character
		local humanoid = character and character:FindFirstChild("Humanoid")

		if not humanoid or not CFrameSpeedActive then
			return end

		if originalWalkSpeed == 16 then
			originalWalkSpeed = humanoid.WalkSpeed
		end

		-- Direct velocity method (more reliable in Da Hood than just WalkSpeed)
		local hrp = character:FindFirstChild("HumanoidRootPart")
		if hrp then
			local moveDir = humanoid.MoveDirection
			if moveDir.Magnitude > 0 then
				local targetSpeed = (SpeedStudsPerSecond and SpeedStudsPerSecond > 16) and SpeedStudsPerSecond or (originalWalkSpeed * GetSpeedMultiplier())
				hrp.Velocity = Vector3.new(moveDir.X * targetSpeed, hrp.Velocity.Y, moveDir.Z * targetSpeed)
			end
		end

		-- Also try WalkSpeed as backup
		local targetWalk = (SpeedStudsPerSecond and SpeedStudsPerSecond > 16) and SpeedStudsPerSecond or (originalWalkSpeed * GetSpeedMultiplier())
		humanoid.WalkSpeed = targetWalk
	end)
end

local function stopSpeed()
	CFrameSpeedActive = false
	if speedConnection then
		speedConnection:Disconnect()
		speedConnection = nil
	end
	local character = LocalPlayer.Character
	local humanoid = character and character:FindFirstChild("Humanoid")
	if humanoid and originalWalkSpeed then
		humanoid.WalkSpeed = originalWalkSpeed
	end
end

