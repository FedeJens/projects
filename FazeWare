flyConnection = RunService.RenderStepped:Connect(function(deltaTime)
	if CFrameFlyActive then
		local character = LocalPlayer.Character
		local hrp = character and character:FindFirstChild("HumanoidRootPart")
		
		if not hrp then return end
		
		local moveDirection = Vector3.new(0, 0, 0)
		local camCF = Camera.CFrame
		
		inputFlags.forward = UserInputService:IsKeyDown(Enum.KeyCode.W)
		inputFlags.back = UserInputService:IsKeyDown(Enum.KeyCode.S)
		inputFlags.left = UserInputService:IsKeyDown(Enum.KeyCode.A)
		inputFlags.right = UserInputService:IsKeyDown(Enum.KeyCode.D)
		inputFlags.up = UserInputService:IsKeyDown(Enum.KeyCode.Space)
		inputFlags.down = UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
		
		if inputFlags.forward then moveDirection = moveDirection + camCF.LookVector end
		if inputFlags.back then moveDirection = moveDirection - camCF.LookVector end
		if inputFlags.left then moveDirection = moveDirection - camCF.RightVector end
		if inputFlags.right then moveDirection = moveDirection + camCF.RightVector end
		if inputFlags.up then moveDirection = moveDirection + Vector3.new(0, 1, 0) end
		if inputFlags.down then moveDirection = moveDirection - Vector3.new(0, 1, 0) end
		
		if moveDirection.Magnitude > 0 then
			moveDirection = moveDirection.Unit
		end
		
		if bodyVelocity then
			bodyVelocity.Velocity = moveDirection * GetFlySpeed()
		end
		if bodyGyro then
			bodyGyro.CFrame = camCF
		end
	end
end)

